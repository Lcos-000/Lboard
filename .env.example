# Server
WB_SERVER_ADDR=:8080
WB_SERVER_GIN_MODE=debug
WB_LOG_LEVEL=debug

# PostgreSQL
POSTGRES_DB=whiteboard
POSTGRES_USER=whiteboard
POSTGRES_PASSWORD=whiteboard
WB_POSTGRES_DSN=postgres://whiteboard:whiteboard@postgres:5432/whiteboard?sslmode=disable

# Redis
WB_REDIS_ADDR=redis:6379
WB_REDIS_PASSWORD=
WB_REDIS_DB=0

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
WB_MINIO_ENDPOINT=minio:9000
WB_MINIO_ACCESS_KEY=minioadmin
WB_MINIO_SECRET_KEY=minioadmin
WB_MINIO_USE_SSL=false
WB_MINIO_BUCKET=whiteboard